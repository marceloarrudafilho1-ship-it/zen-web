# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# Postgres connection string. On Railway, attach a Postgres plugin to the
# service and Railway will inject DATABASE_URL automatically.
DATABASE_URL=postgres://user:pass@host:5432/zen

# Long random string used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Required to create a new account. Share this out-of-band with people you
# want to grant access. Changing it rotates who can sign up going forward;
# existing accounts keep working.
INVITE_CODE=changeme

# Optional second invite code. Accounts signed up with this code get
# ai_enabled=true and unlock the "Explain this wallet" feature. Rotate
# independently of INVITE_CODE. Leave unset to disable premium signups.
INVITE_CODE_PREMIUM=

# Optional Anthropic API key for AI features. Required for the "Explain this
# wallet" button (Opus 4.7). Without it, AI endpoints return 503.
ANTHROPIC_API_KEY=

# NOWNodes API key, used to serve on-chain data to premium users
# (ai_enabled=true) without making them bring their own provider keys.
# Get a key at https://nownodes.io/. With this set:
#   - Premium users automatically use NOWNodes for Bitcoin and Litecoin lookups
#   - Free users continue using the public mempool.space / litecoinspace.org
# Leave unset to disable proxy lookups (premium users fall back to direct API).
NOWNODES_API_KEY=

# Port Express listens on. Railway sets this for you in prod — leave unset
# locally to default to 3001.
# PORT=3001

# NODE_ENV=development for local, production on Railway.
# NODE_ENV=development
