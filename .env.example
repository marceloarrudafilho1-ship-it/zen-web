# Copy to .env for local dev. On Railway, set these in the service Variables tab.

# Postgres connection string. On Railway, attach a Postgres plugin to the
# service and Railway will inject DATABASE_URL automatically.
DATABASE_URL=postgres://user:pass@host:5432/zen

# Long random string used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Required to create a new account. Share this out-of-band with people you
# want to grant access. Changing it rotates who can sign up going forward;
# existing accounts keep working.
INVITE_CODE=changeme

# Port Express listens on. Railway sets this for you in prod — leave unset
# locally to default to 3001.
# PORT=3001

# NODE_ENV=development for local, production on Railway.
# NODE_ENV=development
